{
  "name": "nodejs_backend_prod_template",
  "version": "1.0.0",
  "description": "A basic Nodejs backend production level template using Express, Postgres, TypeORM and Typescript.",
  "main": "dist/server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "dev": "nodemon src/server.ts",
    "dev:worker-jobs": "npx ts-node src/jobs/workers/index.ts",
    "dev:worker-cron": "npx ts-node src/cron/index.ts",
    "dev:worker-onboarding": "npx ts-node src/jobs/workers/onboarding.worker.ts",
    "dev:worker-timeout-demo": "npx ts-node src/jobs/workers/timeout-demo.worker.ts",
    "build": "rm -rf dist && tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/jobs/workers/index.js",
    "start:worker-onboarding": "node dist/jobs/workers/onboarding.worker.js",
    "clean": "rm -rf dist",
    "migration:generate": "npx ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d src/database/database.ts src/database/migrations/migrationName",
    "migration:run": "npx ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/database/database.ts",
    "migration:revert": "npx ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d src/database/database.ts",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "3.1040.0",
    "@aws-sdk/s3-request-presigner": "3.1040.0",
    "@logtail/node": "^0.5.2",
    "@logtail/winston": "^0.5.2",
    "@sendgrid/mail": "^8.1.5",
    "@slack/types": "^2.21.1",
    "@slack/web-api": "^7.16.0",
    "argon2": "0.43.0",
    "axios": "^1.7.9",
    "bullmq": "^5.47.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.5",
    "cookie-parser": "1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "facebook-nodejs-business-sdk": "^22.0.0",
    "fast-csv": "^5.0.5",
    "fluent-ffmpeg": "^2.1.3",
    "gaxios": "^7.1.1",
    "google-auth-library": "^9.15.1",
    "googleapis": "^148.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.0",
    "iso-3166-2.json": "^0.1.2",
    "jsonwebtoken": "9.0.2",
    "moment-timezone": "^0.5.47",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.0",
    "openai": "^5.0.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "regression": "^2.0.1",
    "typeorm": "^0.3.20",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-syslog": "^2.7.1",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/facebook-nodejs-business-sdk": "^20.0.2",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/regression": "^2.0.6",
    "@types/winston-syslog": "^2.4.3",
    "cross-env": "^7.0.3",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^15.14.0",
    "nodemon": "^3.1.9",
    "prettier": "3.4.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0"
  },
  "overrides": {
    "eslint": "^9.19.0"
  }
}
