NODE_ENV=development
PORT=3000
APP_DEBUG=false

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=mydb
DATABASE_POOL_MAX=20

# JWT (RS256) — PEM keys base64-encoded
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KEY_ID=v1
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# Cookies
COOKIE_DOMAIN=

# Auth rate limiting (Postgres-backed)
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MINUTES=15

# Email (nodemailer Gmail SMTP)
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_CLIENT_URL=http://localhost:3000

# Logging
LOG_LEVEL=error
LOGTAIL_TOKEN=
LOGTAIL_INGESTION_ENDPOINT=

# Redis (BullMQ workers)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
